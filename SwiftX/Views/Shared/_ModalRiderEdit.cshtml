@{

}

<div class="admin-modal-overlay" id="rider-edit-modal">
    <div class="admin-modal admin-modal--lg">
        <div class="admin-modal__header">
            <h2 class="admin-modal__title">
                <i class="ph ph-pencil-simple"></i> Edit Rider Profile
            </h2>
            <button class="admin-modal__close" onclick="closeModal('rider-edit-modal')">
                <i class="ph ph-x"></i>
            </button>
        </div>
        <div class="admin-modal__body">

            <!-- ── Hero ── -->
            <div class="rmod-hero">
                <div class="rmod-hero__av-wrap">
                    <img class="rmod-hero__av-img"
                         src="~/Assets/images/profile.jpg"
                         alt="James Ocampo"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                    <div class="rmod-hero__av-fallback" style="display:none;">
                        <i class="ph ph-user"></i>
                    </div>
                    <span class="rmod-hero__av-dot rmod-hero__av-dot--active"></span>
                </div>
                <div>
                    <p class="rmod-hero__name">James Ocampo</p>
                    <div class="rmod-hero__meta">
                        <span class="rmod-hero__id">Rider-001</span>
                        <span class="admin-badge admin-badge--active">
                            <span class="admin-badge-dot"></span>Active
                        </span>
                    </div>
                </div>
                <div class="rmod-hero__btns">
                    <button class="admin-modal-btn admin-modal-btn--ghost">
                        <i class="ph ph-camera"></i> Change Photo
                    </button>
                </div>
            </div>

            <!-- ── Personal Information ── -->
            <p class="emod-section-title">
                <i class="ph ph-identification-card"></i> Personal Information
            </p>
            <div class="emod-grid">
                <div class="emod-field">
                    <span class="emod-field__label">Full Name</span>
                    <input class="admin-modal-input" type="text" value="James Ocampo" placeholder="Full name" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Date of Birth</span>
                    <input class="admin-modal-input" type="date" value="2000-03-15" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Phone</span>
                    <input class="admin-modal-input" type="text" value="09292-096-887" placeholder="Phone number" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Email</span>
                    <input class="admin-modal-input" type="email" value="james@email.com" placeholder="Email address" />
                </div>
                <div class="emod-field emod-field--full">
                    <span class="emod-field__label">Address</span>
                    <input class="admin-modal-input" type="text" value="Purok 2, Brgy. Cawayan, Valencia City" placeholder="Full address" />
                </div>
            </div>

            <!-- ── Vehicle Information ── -->
            <p class="emod-section-title">
                <i class="ph ph-motorcycle"></i> Vehicle Information
            </p>
            <div class="emod-grid">
                <div class="emod-field">
                    <span class="emod-field__label">Vehicle Type</span>
                    <input class="admin-modal-input" type="text" value="Motorcycle" placeholder="e.g. Motorcycle" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Vehicle Model</span>
                    <input class="admin-modal-input" type="text" value="Honda Click 125i" placeholder="Brand & model" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Plate Number</span>
                    <input class="admin-modal-input" type="text" value="ABC-123" placeholder="Plate number" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">License Number</span>
                    <input class="admin-modal-input" type="text" value="DL-0011223" placeholder="License number" />
                </div>
            </div>

            <!-- ── Payment Information ── -->
            <p class="emod-section-title">
                <i class="ph ph-wallet"></i> Payment Information
            </p>
            <div class="emod-grid">
                <div class="emod-field">
                    <span class="emod-field__label">Payment Method</span>
                    <input class="admin-modal-input" type="text" value="GCash" placeholder="e.g. GCash, Bank" />
                </div>
                <div class="emod-field">
                    <span class="emod-field__label">Account Number</span>
                    <input class="admin-modal-input" type="text" value="09292-096-887" placeholder="Account / number" />
                </div>
            </div>

            <!-- ── Footer ── -->
            <div class="emod-footer">
                <button class="admin-modal-btn admin-modal-btn--ghost"
                        onclick="closeModal('rider-edit-modal')">
                    Cancel
                </button>
                <button class="admin-modal-btn admin-modal-btn--approve">
                    <i class="ph ph-floppy-disk"></i> Save Changes
                </button>
            </div>

        </div>
    </div>
</div>
