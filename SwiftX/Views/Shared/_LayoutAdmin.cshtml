@{
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SwiftX</title>

   
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />  <!-- CDN-like link for Tailwind CSS -->
    <link rel="stylesheet" href="~/css/admin/admin.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">


    <!-- PHOSPOR ICONS -->
    <link rel="stylesheet" href="~/lib/phosphor-icons/regular/style.css" />
    <link rel="stylesheet" href="~/lib/phosphor-icons/bold/style.css" />
    <link rel="stylesheet" href="~/lib/phosphor-icons/fill/style.css" />

</head>
<body class="__fullpage">
    <div class="admin-layout">
        <!-- SIDE BAR NAV -->
        <div class="admin-sidebar-overlay"></div>

        <aside class="admin-sidebar">
            <div class="admin-sidebar-logo">
                <img src="~/assets/images/swiftX_logo.png" alt="SwiftX" />
                <span>Admin</span>
            </div>

            <nav class="admin-sidebar-nav">
                <div class="admin-nav-group">
                    <p class="admin-nav-group-label">Main</p>
                    <a asp-area="" asp-controller="Admin" asp-action="Dashboard" class="admin-nav-item">
                        <i class="ph ph-squares-four"></i> Dashboard
                    </a>
                    <a asp-area="" asp-controller="Admin" asp-action="#" class="admin-nav-item">
                        <i class="ph ph-package"></i> Orders
                    </a>
                </div>
                <div class="admin-nav-group">
                    <p class="admin-nav-group-label">Management</p>
                    <a asp-area="" asp-controller="Admin" asp-action="#" class="admin-nav-item">
                        <i class="ph ph-motorcycle"></i> Riders
                    </a>
                    <a asp-area="" asp-controller="Admin" asp-action="#" class="admin-nav-item">
                        <i class="ph ph-storefront"></i> Merchants
                    </a>
                </div>
                <div class="admin-nav-group">
                    <p class="admin-nav-group-label">System</p>
                    <a asp-area="" asp-controller="Admin" asp-action="#" class="admin-nav-item">
                        <i class="ph ph-gear"></i> Settings
                    </a>
                </div>
            </nav>

            <div class="admin-sidebar-footer">
                <div class="admin-user-info">
                    <div class="admin-user-avatar">
                        <i class="ph ph-user"></i>
                    </div>
                    <div>
                        <p class="admin-user-name">Admin User</p>
                        <p class="admin-user-role">Super Admin</p>
                    </div>
                </div>
                <a asp-area="" asp-controller="Admin" asp-action="#" class="admin-nav-item" style="margin-top:4px;">
                    <i class="ph ph-sign-out"></i> Sign Out
                </a>
            </div>
        </aside>

        <main role="main" class="admin-main">
            <header class="admin-topbar">
                <div class="admin-topbar-left">
                    <button type="button" class="admin-topbar-btn admin-sidebar-toggle" aria-label="Toggle sidebar">
                        <i class="ph ph-list"></i>
                    </button>
                    <h1 class="admin-topbar-title">Merchants</h1>
                </div>
                <div class="admin-topbar-right">
                    <button type="button" class="admin-topbar-btn" aria-label="Notifications">
                        <i class="ph ph-bell"></i>
                    </button>
                </div>
            </header>


            @RenderBody()


        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
