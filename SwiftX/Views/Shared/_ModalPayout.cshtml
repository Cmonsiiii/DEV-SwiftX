}

<div class="admin-modal-overlay" id="payout-modal">
    <div class="admin-modal admin-modal--md">
        <div class="admin-modal__header">
            <h2 class="admin-modal__title">
                <i class="ph ph-currency-circle-dollar"></i> Confirm &amp; Process Batch Payouts
            </h2>
            <button class="admin-modal__close" onclick="closeModal('payout-modal')"><i class="ph ph-x"></i></button>
        </div>
        <div class="admin-modal__body"> 

            <!-- Summary stats — uses .admin-modal-stats-row + .admin-modal-stat-card from admin-riders.css -->
            <div class="admin-modal-stats-row">
                <div class="admin-modal-stat-card">
                    <p class="admin-modal-stat-card__value">5</p>
                    <p class="admin-modal-stat-card__label">Pending Riders</p>
                </div>
                <div class="admin-modal-stat-card">
                    <p class="admin-modal-stat-card__value">&#8369;50,000</p>
                    <p class="admin-modal-stat-card__label">Net Disbursement</p>
                </div>
                <div class="admin-modal-stat-card">
                    <p class="admin-modal-stat-card__value">&#8369;150,000</p>
                    <p class="admin-modal-stat-card__label">Revenue Balance</p>
                </div>
            </div>

            <!-- Payout breakdown table -->
            <div class="admin-modal-table-wrap" style="margin-top:20px;">
                <table class="admin-table admin-table--compact">
                    <thead>
                        <tr>
                            <th>Rider ID</th>
                            <th>Name</th>
                            <th>Earnings (Net)</th>
                            <th>Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Rider-001</td>
                            <td>James Ocampo</td>
                            <td>&#8369;10,000</td>
                            <td>GCash</td>
                        </tr>
                        <tr>
                            <td>Rider-002</td>
                            <td>Mark Villanueva</td>
                            <td>&#8369;10,000</td>
                            <td>GCash</td>
                        </tr>
                        <tr>
                            <td>Rider-005</td>
                            <td>Leo Fernandez</td>
                            <td>&#8369;10,000</td>
                            <td>Online Bank</td>
                        </tr>
                        <tr>
                            <td>Rider-007</td>
                            <td>Josh Ycaro</td>
                            <td>&#8369;10,000</td>
                            <td>Online Bank</td>
                        </tr>
                        <tr>
                            <td>Rider-008</td>
                            <td>Nico Santos</td>
                            <td>&#8369;10,000</td>
                            <td>Online Bank</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Warning banner -->
            <div class="admin-modal-warning">
                <i class="ph ph-warning"></i>
                <p>
                    You are about to disburse a total of <strong>&#8369;50,000</strong>.
                    This action is irreversible. Funds will be deducted from your available revenue balance.
                </p>
            </div>

            <!-- Actions -->
            <div class="admin-modal-footer-actions">
                <button class="admin-modal-btn admin-modal-btn--ghost"
                        onclick="closeModal('payout-modal')">
                    Cancel
                </button>
                <button class="admin-modal-btn admin-modal-btn--danger">
                    <i class="ph ph-check"></i> Confirm Payment
                </button>
            </div>

        </div>
    </div>
</div>
