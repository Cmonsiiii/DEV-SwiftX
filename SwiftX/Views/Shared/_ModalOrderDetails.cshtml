@{
}
<!-- ── Order Detail Modal ── -->
<div class="admin-modal-overlay" id="order-detail-modal"
     onclick="if(event.target===this)closeModal('order-detail-modal')">
    <div class="admin-modal admin-modal--lg">

        <div class="admin-modal__scroll">

            <!-- ── Hero ── -->
            <div class="omod-hero">
                <div class="omod-hero__left">
                    <p class="omod-hero__label">Order ID</p>
                    <p class="omod-hero__id">#ORD-1248</p>
                    <div class="omod-hero__chips">
                        <span class="admin-badge admin-badge--delivered">
                            <span class="admin-badge-dot"></span>Delivered
                        </span>
                        <span class="rmod-hero__chip">
                            <i class="ph ph-calendar-blank"></i> Feb 21, 2026 &middot; 2:34 PM
                        </span>
                    </div>
                </div>
                <button class="admin-modal__close" onclick="closeModal('order-detail-modal')">
                    <i class="ph ph-x"></i>
                </button>
            </div>

            <!-- ── 2-col body ── -->
            <div class="omod-body">

                <!-- LEFT: People involved -->
                <div class="omod-col">

                    <div class="admin-modal-section">
                        <p class="admin-modal-section__label">Customer</p>
                        <div class="omod-party">
                            <div class="omod-party__av omod-party__av--customer">
                                <i class="ph ph-user"></i>
                            </div>
                            <div>
                                <p class="omod-party__name">Maria Santos</p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-phone"></i> 0917-123-4567
                                </p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-map-pin"></i> 123 Rizal St., Malaybalay City, Bukidnon
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="admin-modal-section">
                        <p class="admin-modal-section__label">Rider</p>
                        <div class="omod-party">
                            <div class="omod-party__av omod-party__av--rider">
                                <i class="ph ph-motorcycle"></i>
                            </div>
                            <div>
                                <p class="omod-party__name">James Ocampo</p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-phone"></i> 0921-567-8901
                                </p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-tag"></i> Rider-003 &middot;
                                    <span class="td-plate td-plate--xs">ABC-123</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="admin-modal-section">
                        <p class="admin-modal-section__label">Merchant</p>
                        <div class="omod-party">
                            <div class="omod-party__av omod-party__av--merchant">
                                <i class="ph ph-storefront"></i>
                            </div>
                            <div>
                                <p class="omod-party__name">Jollibee Malaybalay</p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-phone"></i> 088-212-3456
                                </p>
                                <p class="omod-party__sub">
                                    <i class="ph ph-map-pin"></i> CM Recto Ave., Malaybalay City, Bukidnon
                                </p>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- RIGHT: Items + Breakdown -->
                <div class="omod-col">

                    <div class="admin-modal-section">
                        <p class="admin-modal-section__label">Order Items</p>
                        <div class="omod-items">
                            <div class="omod-item">
                                <span class="omod-item__qty">2&times;</span>
                                <span class="omod-item__name">Chickenjoy (1pc)</span>
                                <span class="omod-item__price">&#8369;134</span>
                            </div>
                            <div class="omod-item">
                                <span class="omod-item__qty">1&times;</span>
                                <span class="omod-item__name">Jolly Spaghetti</span>
                                <span class="omod-item__price">&#8369;65</span>
                            </div>
                            <div class="omod-item">
                                <span class="omod-item__qty">2&times;</span>
                                <span class="omod-item__name">Burger Steak (1pc)</span>
                                <span class="omod-item__price">&#8369;86</span>
                            </div>
                            <div class="omod-item">
                                <span class="omod-item__qty">1&times;</span>
                                <span class="omod-item__name">Peach Mango Pie</span>
                                <span class="omod-item__price">&#8369;29</span>
                            </div>
                            <div class="omod-item">
                                <span class="omod-item__qty">3&times;</span>
                                <span class="omod-item__name">Regular Fries</span>
                                <span class="omod-item__price">&#8369;90</span>
                            </div>
                            <div class="omod-item">
                                <span class="omod-item__qty">2&times;</span>
                                <span class="omod-item__name">Coke Float (Med)</span>
                                <span class="omod-item__price">&#8369;58</span>
                            </div>
                        </div>
                    </div>

                    <div class="admin-modal-section">
                        <p class="admin-modal-section__label">Price Breakdown</p>
                        <div class="omod-breakdown">
                            <div class="omod-breakdown__row">
                                <span>Subtotal</span>
                                <span>&#8369;462</span>
                            </div>
                            <div class="omod-breakdown__row">
                                <span>Delivery Fee</span>
                                <span>&#8369;49</span>
                            </div>
                            <div class="omod-breakdown__row">
                                <span>Discount</span>
                                <span class="omod-breakdown__discount">&#8722; &#8369;226</span>
                            </div>
                            <div class="omod-breakdown__divider"></div>
                            <div class="omod-breakdown__row omod-breakdown__row--total">
                                <span>Total</span>
                                <span>&#8369;285</span>
                            </div>
                            <div class="omod-breakdown__row omod-breakdown__payment">
                                <span class="omod-breakdown__payment-label">Payment Method</span>
                                <span class="omod-breakdown__payment-value">
                                    <i class="ph ph-device-mobile"></i> GCash
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div><!-- /.admin-modal__scroll -->
        <!-- ── Footer ── -->
        <div class="omod-footer">
            <p class="omod-footer__note">
                <i class="ph ph-info"></i>
                Actions here are irreversible. Make sure before confirming.
            </p>
            <div class="omod-footer__actions">
                <button class="admin-modal-btn admin-modal-btn--ghost"
                        onclick="closeModal('order-detail-modal')">
                    Close
                </button>
                <button class="admin-modal-btn admin-modal-btn--warning">
                    <i class="ph ph-arrow-counter-clockwise"></i> Reassign Rider
                </button>
                <button class="admin-modal-btn admin-modal-btn--danger">
                    <i class="ph ph-flag"></i> Report Issue
                </button>
                <button class="admin-modal-btn admin-modal-btn--danger-outline">
                    <i class="ph ph-x-circle"></i> Cancel Order
                </button>
                <button class="admin-modal-btn admin-modal-btn--success">
                    <i class="ph ph-check-circle"></i> Mark as Delivered
                </button>
            </div>
        </div>

    </div>
</div>
