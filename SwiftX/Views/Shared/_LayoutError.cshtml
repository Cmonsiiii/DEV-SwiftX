@{
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SwiftX</title>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" /> <!-- CDN for Tailwind CSS-->

    <link rel="stylesheet" href="~/lib/phosphor-icons/regular/style.css" />
    <link rel="stylesheet" href="~/lib/phosphor-icons/bold/style.css" />
    <link rel="stylesheet" href="~/lib/phosphor-icons/fill/style.css" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">

</head>
<body class="__fullpage">
    <header>
        <nav class="sticky top-0 z-50 flex items-center justify-between px-5 py-4 md:px-8 bg-[var(--dark-bg-nav)] backdrop-blur-xl border-b border-white/[0.06]" aria-label="Main navigation">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center text-inherit no-underline" aria-label="SwiftX Home">
                <img src="~/Assets/images/swiftX_logo.png" alt="SwiftX" class="h-9 w-auto block" />
            </a>
        </nav>
    </header>
    <main role="main" class="__main mt-0 flex items-center justify-center">
        @RenderBody()
    </main>

    <footer id="contact" class="px-6 py-10 md:py-12 bg-[var(--dark-bg-hero)] text-[var(--light-text-color)]">
        <div class="mt-10 flex flex-col md:flex-row items-center justify-evenly gap-4 text-sm opacity-80">
            <span class="text-[var(--primary-color)]">2026 © SwiftX All Rights Reserved</span>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/multistep-form.js"></script>
    <script src="~/js/rider_signup.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>