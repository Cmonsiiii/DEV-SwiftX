@{
    Layout = "~/Views/Shared/_LayoutError.cshtml";
}
<section class="relative flex items-center justify-center min-h-[80vh] w-full overflow-hidden">
    <!-- Background glows -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full opacity-[0.05] __glow-bg"></div>
    </div>

    <div class="relative flex flex-col items-center text-center px-6 py-16 md:py-20 text-[var(--light-text-color)]">
        <!-- Animated gears -->
        <div class="__fade-up __fade-up--d1 mb-8">
            <div class="relative w-28 h-28 mx-auto flex items-center justify-center">
                <!-- Large gear -->
                <svg class="__gear-spin absolute w-20 h-20 text-[var(--primary-color)] opacity-80" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97s-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1s.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64L19.43 12.97z" />
                </svg>
                <!-- Small gear -->
                <svg class="__gear-spin-reverse absolute w-10 h-10 text-[var(--primary-color)] opacity-50 top-0 -right-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97s-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1s.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64L19.43 12.97z" />
                </svg>
            </div>
        </div>

        <h1 class="__h2 __fade-up __fade-up--d2 max-w-xl">
            We're <span class="text-[var(--primary-color)]">Upgrading</span> Things
        </h1>

        <p class="__body-lg __fade-up __fade-up--d3 mt-4 max-w-md opacity-60 leading-relaxed">
            SwiftX is currently undergoing scheduled maintenance to bring you a better experience. We'll be back shortly.
        </p>

        <!-- Progress bar -->
        <div class="__fade-up __fade-up--d3 w-full max-w-xs mt-8">
            <div class="__progress-track">
                <div class="__progress-bar __progress-pulse"></div>
            </div>
        </div>

        <!-- Info cards -->
        <div class="__fade-up __fade-up--d4 grid sm:grid-cols-2 gap-4 mt-12 max-w-lg w-full">
            <div class="__info-card">
                <div class="__icon-box w-10 h-10 mb-3 mx-auto">
                    <i class="ph ph-clock text-[20px]"></i>
                </div>
                <p class="__small font-medium opacity-80">Expected Duration</p>
                <p class="__micro opacity-40 mt-1">A few hours at most</p>
            </div>
            <div class="__info-card">
                <div class="__icon-box w-10 h-10 mb-3 mx-auto">
                    <i class="ph ph-bell text-[20px]"></i>
                </div>
                <p class="__small font-medium opacity-80">Stay Updated</p>
                <p class="__micro opacity-40 mt-1">Follow us on social media</p>
            </div>
        </div>

        <!-- Social links -->
        <div class="__fade-up __fade-up--d4 mt-10 pt-8 border-t border-white/[0.06]">
            <p class="__small opacity-40 mb-4">Follow us for updates</p>
            <div class="flex items-center justify-center gap-3">
                <a href="#" class="__social-icon" aria-label="Facebook">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12a10 10 0 10-11.5 9.9v-7H8v-3h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.3.2 2.3.2v2.5h-1.3c-1.3 0-1.7.8-1.7 1.6V12H18l-.4 3h-2.7v7A10 10 0 0022 12z" /></svg>
                </a>
                <a href="#" class="__social-icon" aria-label="Email">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l9 6 9-6M5 6h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" /></svg>
                </a>
                <a href="#" class="__social-icon" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4H8a4 4 0 00-4 4v8a4 4 0 004 4h8a4 4 0 004-4V8a4 4 0 00-4-4z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16a4 4 0 100-8 4 4 0 000 8z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.5 6.5h.01" /></svg>
                </a>
            </div>
        </div>
    </div>
</section>