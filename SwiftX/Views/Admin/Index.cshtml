
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}
<!-- Background Glow -->
<div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full __hero-glow-lg __glow-bg"></div>
    <div class="absolute -bottom-48 -left-48 w-[400px] h-[400px] rounded-full __hero-glow-sm __glow-bg"></div>
</div>



<!-- Login Card -->
<div class="relative w-full max-w-md mx-auto px-5 py-12 md:py-16">

    <!-- Logo -->
    <div class="flex justify-center mb-8 __fade-up __fade-up--d1">
        <a asp-area="" asp-controller="Home" asp-action="Index" aria-label="SwiftX Home">
            <img src="~/assets/images/swiftX_logo.png" alt="SwiftX" class="h-10 w-auto block" />
        </a>
    </div>
    <div class="text-center mb-8 __fade-up __fade-up--d2">
        <span class="__pill mb-4">Admin Portal</span>
    </div>

    <!-- Login Form -->
    <form id="admin-login-form" class="__fade-up __fade-up--d3" novalidate>
        <div class="login-card">

            <!-- Error Banner (hidden by default) -->
            <div class="login-error-banner hidden" id="login-error-banner">
                <i class="ph ph-warning-circle"></i>
                <span>Invalid username or password.</span>
            </div>

            <!-- Username -->
            <div class="mb-4">
                <label class="__label block mb-1.5" for="login-username">Username</label>
                <div class="login-input-wrapper">
                    <i class="ph ph-user login-input-icon"></i>
                    <input type="text"
                           id="login-username"
                           class="login-input"
                           placeholder="Enter your username"
                           autocomplete="username"
                           data-login-field />
                </div>
                <span class="field-error" data-error="username"></span>
            </div>

            <!-- Password -->
            <div class="mb-5">
                <label class="__label block mb-1.5" for="login-password">Password</label>
                <div class="password-wrapper">
                    <div class="login-input-wrapper">
                        <i class="ph ph-lock login-input-icon"></i>
                        <input type="password"
                               id="login-password"
                               class="login-input"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               data-login-field />
                    </div>
                    <button type="button" class="password-toggle" data-toggle-pw aria-label="Toggle password visibility">
                        <i class="ph ph-eye eye-open"></i>
                        <i class="ph ph-eye-slash eye-closed hidden"></i>
                    </button>
                </div>
                <span class="field-error" data-error="password"></span>
            </div>

            <!-- Remember Me & Forgot -->
            <div class="flex items-center justify-between mb-6">
                <a href="#" class="__small __text-primary opacity-80 hover:opacity-100 transition-opacity no-underline">Forgot password?</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-next" id="btn-login" disabled>
                <span class="btn-login-text">Sign In</span>
                <span class="btn-login-loader hidden">
                    <i class="ph ph-circle-notch login-spinner"></i>
                    Signing in...
                </span>
            </button>
        </div>
    </form>

    <div class="text-center mt-6 __fade-up __fade-up--d4">
        <a asp-area="" asp-controller="Admin" asp-action="Dashboard" class="inline-flex items-center gap-2 __small opacity-50 hover:opacity-100 __footer-link transition-opacity no-underline">
            Admin Page
        </a>
    </div>
</div>