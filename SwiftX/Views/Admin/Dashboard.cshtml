@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="dash-welcome">
    <div class="dash-welcome__left">
        <p class="dash-welcome__greeting">Welcome back</p>
        <h2 class="dash-welcome__name">Admin User</h2>
        <p class="dash-welcome__sub">Here's what's happening with SwiftX today.</p>
    </div>
    <div class="dash-welcome__date">
        <strong id="dash-date">—</strong>
        <span id="dash-time">—</span>
    </div>
</div>

@* {{-- ── Stat Cards ── --}} *@
<div class="admin-stat-grid">
    <div class="admin-stat-card">
        <div class="admin-stat-header">
            <div class="admin-stat-icon"><i class="ph ph-package"></i></div>
            <span class="admin-stat-badge admin-stat-badge--up">
                <i class="ph ph-arrow-up"></i> 12%
            </span>
        </div>
        <p class="admin-stat-value">1,248</p>
        <p class="admin-stat-label">Total Orders</p>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-header">
            <div class="admin-stat-icon"><i class="ph ph-motorcycle"></i></div>
            <span class="admin-stat-badge admin-stat-badge--up">
                <i class="ph ph-arrow-up"></i> 8%
            </span>
        </div>
        <p class="admin-stat-value">86</p>
        <p class="admin-stat-label">Active Riders</p>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-header">
            <div class="admin-stat-icon"><i class="ph ph-storefront"></i></div>
            <span class="admin-stat-badge admin-stat-badge--up">
                <i class="ph ph-arrow-up"></i> 5%
            </span>
        </div>
        <p class="admin-stat-value">42</p>
        <p class="admin-stat-label">Partner Merchants</p>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-header">
            <div class="admin-stat-icon"><i class="ph ph-currency-circle-dollar"></i></div>
            <span class="admin-stat-badge admin-stat-badge--neutral">
                <i class="ph ph-minus"></i> 0%
            </span>
        </div>
        <p class="admin-stat-value">&#8369;184,520</p>
        <p class="admin-stat-label">Revenue (This Month)</p>
    </div>
</div>

@* 
{{-- ── Application Summary ── --}} 
*@

<div class="dash-app-grid">

    <a asp-area="" asp-controller="Admin" asp-action="RiderApplications" class="dash-app-card">
        <div class="dash-app-card__icon">
            <i class="ph ph-user-circle-plus"></i>
        </div>
        <div class="dash-app-card__body">
            <p class="dash-app-card__label">Applications</p>
            <p class="dash-app-card__title">Rider Applications</p>
            <div class="dash-app-card__pills">
                @* PENDING *@
                <span class="dash-app-pill dash-app-pill--pending">
                    <span class="dash-app-pill__dot"></span>4 Pending
                </span>
                @*
                    ==== APPROVED ====
                <span class="dash-app-pill dash-app-pill--approved">
                    <span class="dash-app-pill__dot"></span>12 Approved
                </span>
                    ==== REJECTED ===
                <span class="dash-app-pill dash-app-pill--rejected">
                    <span class="dash-app-pill__dot"></span>2 Rejected
                </span>
                *@
            </div>
        </div>
        <span class="dash-app-card__action">
            Review <i class="ph ph-arrow-right"></i>
        </span>
    </a>

    <a asp-area="" asp-controller="Admin" asp-action="MerchantApplications" class="dash-app-card">
        <div class="dash-app-card__icon">
            <i class="ph ph-clipboard-text"></i>
        </div>
        <div class="dash-app-card__body">
            <p class="dash-app-card__label">Applications</p>
            <p class="dash-app-card__title">Merchant Applications</p>
            <div class="dash-app-card__pills">

                @* PENDING *@
                <span class="dash-app-pill dash-app-pill--pending">
                    <span class="dash-app-pill__dot"></span>6 Pending
                </span>
                @*
                    ==== APPROVED ====
                    <span class="dash-app-pill dash-app-pill--approved">
                        <span class="dash-app-pill__dot"></span>8 Approved
                    </span>

                    ==== REJECTED ===
                    <span class="dash-app-pill dash-app-pill--rejected">
                        <span class="dash-app-pill__dot"></span>1 Rejected
                    </span>
                *@
            </div>
        </div>
        <span class="dash-app-card__action">
            Review <i class="ph ph-arrow-right"></i>
        </span>
    </a>

</div>

@*
    {{-- ── Bottom Grid: Recent Orders + Activity ── --}} 
*@

<div class="dash-bottom-grid">

    <div class="admin-table-card admin-table-card--flush">
        <div class="admin-table-header">
            <div>
                <h2 class="admin-table-title">Recent Orders</h2>
                <p class="admin-table-subtitle">Last 5 transactions</p>
            </div>
            <a asp-area="" asp-controller="Admin" asp-action="Orders" class="dash-view-all">
                View All <i class="ph ph-arrow-right"></i>
            </a>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table" id="recent_orders">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Merchant</th>
                        <th>Status</th>
                        <th>Amount</th>
                    </tr>
                </thead>

                @* MAKE IT 5 ROWS ONLY *@
                <tbody>
                    @* DELIVERED *@
                    <tr>
                        <td><span class="dash-order-id">#ORD-1248</span></td>
                        <td><span class="dash-customer">Maria Santos</span></td>
                        <td><span class="dash-merchant">Jollibee Malaybalay</span></td>
                        <td>
                            <span class="admin-badge admin-badge--delivered">
                                <span class="admin-badge-dot"></span>Delivered
                            </span>
                        </td>
                        <td><span class="dash-amount">&#8369;285</span></td>
                    </tr>
                    @* In Transit / En Route / OTW *@
                    <tr>
                        <td><span class="dash-order-id">#ORD-1247</span></td>
                        <td><span class="dash-customer">Juan Dela Cruz</span></td>
                        <td><span class="dash-merchant">Chowking Valencia</span></td>
                        <td>
                            <span class="admin-badge admin-badge--in-transit">
                                <span class="admin-badge-dot"></span>In Transit
                            </span>
                        </td>
                        <td><span class="dash-amount">&#8369;192</span></td>
                    </tr>
                    @* PENDING *@
                    <tr>
                        <td><span class="dash-order-id">#ORD-1246</span></td>
                        <td><span class="dash-customer">Ana Reyes</span></td>
                        <td><span class="dash-merchant">Mang Inasal</span></td>
                        <td>
                            <span class="admin-badge admin-badge--pending">
                                <span class="admin-badge-dot"></span>Pending
                            </span>
                        </td>
                        <td><span class="dash-amount">&#8369;340</span></td>
                    </tr>
                    @* CANCELLED *@
                    <tr>
                        <td><span class="dash-order-id">#ORD-1244</span></td>
                        <td><span class="dash-customer">Rosa Lim</span></td>
                        <td><span class="dash-merchant">KFC Malaybalay</span></td>
                        <td>
                            <span class="admin-badge admin-badge--cancelled">
                                <span class="admin-badge-dot"></span>Cancelled
                            </span>
                        </td>
                        <td><span class="dash-amount">&#8369;220</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="dash-activity-card">
        <div class="dash-activity-header">
            <h2 class="admin-table-title">Recent Activity</h2>
        </div>
        <ul class="dash-activity-feed">
            @* MAKE IT 5 ACTIVITY ROWS ONLY *@

            @* RIDER ACCEPT ACTIVITY *@
            <li class="dash-activity-item">
                <div class="dash-activity-dot dash-activity-dot--rider">
                    <i class="ph ph-motorcycle"></i>
                </div>
                <div>
                    <p class="dash-activity-text">
                        <strong>Mark Villanueva</strong> submitted a rider application.
                    </p>
                    <p class="dash-activity-time">2 minutes ago</p>
                </div>
            </li>
            @* ORDER DELIVERED ACTIVITY *@
            <li class="dash-activity-item">
                <div class="dash-activity-dot dash-activity-dot--order">
                    <i class="ph ph-package"></i>
                </div>
                <div>
                    <p class="dash-activity-text">
                        Order <strong>#ORD-1248</strong> was delivered successfully.
                    </p>
                    <p class="dash-activity-time">15 minutes ago</p>
                </div>
            </li>
            @* MERCHANT ACCEPT ACTIVITY *@
            <li class="dash-activity-item">
                <div class="dash-activity-dot dash-activity-dot--merchant">
                    <i class="ph ph-storefront"></i>
                </div>
                <div>
                    <p class="dash-activity-text">
                        <strong>Kusina ni Lola</strong> was approved as a merchant partner.
                    </p>
                    <p class="dash-activity-time">1 hour ago</p>
                </div>
            </li>
            @* ORDER CANCELLED ACTIVITY *@
            <li class="dash-activity-item">
                <div class="dash-activity-dot dash-activity-dot--system">
                    <i class="ph ph-warning"></i>
                </div>
                <div>
                    <p class="dash-activity-text">
                        Order <strong>#ORD-1244</strong> was cancelled by customer.
                    </p>
                    <p class="dash-activity-time">2 hours ago</p>
                </div>
            </li>
        </ul>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var recentOrdersTable = $('#recent_orders').DataTable({
                pageLength:   5,
                ordering:     true,
                searching:    false,
                lengthChange: false,
                dom: 't<"admin-pagination"<"dataTables_info"i><"admin-pagination-btns"p>>',
                columnDefs: [{ orderable: false, targets: [4] }],
                language: {
                    paginate: {
                        previous: '<i class="ph ph-caret-left"></i>',
                        next:     '<i class="ph ph-caret-right"></i>'
                    },
                    info: 'Showing _START_–_END_ of _TOTAL_ riders'
                },
                drawCallback: function () {
                    $(this.api().table().container())
                        .find('.dataTables_paginate .paginate_button')
                        .addClass('admin-page-btn')
                        .filter('.current').addClass('active');
                }
            });
        });

        function updateClock() {
            const now = new Date();
            const dateOpts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const timeOpts = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
            document.getElementById('dash-date').textContent = now.toLocaleDateString('en-PH', dateOpts);
            document.getElementById('dash-time').textContent = now.toLocaleTimeString('en-PH', timeOpts);
        }
        updateClock();
        setInterval(updateClock, 1000);
    </script>
}
